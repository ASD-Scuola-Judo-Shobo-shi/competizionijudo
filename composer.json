{
  "name": "competizionijudo/mvc-app",
  "description": "A small MVC application for judo competition registration and administration.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse --debug --memory-limit=256M",
    "check": [
      "@metadata",
      "@syntax",
      "@cs",
      "@analyse",
      "@test",
      "@security:audit"
    ],
    "ci": [
      "@test:migrations",
      "@check",
      "bash scripts/build-deploy.sh",
      "bash scripts/test-deploy-artifact.sh build/deploy"
    ],
    "cs": "phpcs --standard=phpcs.xml",
    "cs:fix": "phpcbf --standard=phpcs.xml",
    "format": "@cs:fix",
    "lint": "@cs",
    "metadata": "composer validate --strict --no-check-lock",
    "security:audit": "composer audit --locked --abandoned=fail",
    "serve": "php -S 0.0.0.0:8080 -t public public/index.php",
    "syntax": "find config public routes scripts src tests views -name '*.php' -print0 | xargs -0 -n1 php -l",
    "migrate": "php scripts/run-migrations.php",
    "privacy:purge": "php scripts/purge-expired-data.php",
    "test:migrations": "php scripts/test-migrations.php",
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": false,
    "sort-packages": true
  }
}

# Local-only environment for development tooling.
# Copy this file to .env.dev and keep real local credentials out of Git.

# The migration smoke harness creates and drops only databases derived from this
# prefix. It must start with competizionijudo_test_.
MIGRATION_TEST_DATABASE_PREFIX=competizionijudo_test_local
MIGRATION_TEST_HOST=127.0.0.1
MIGRATION_TEST_PORT=3306
MIGRATION_TEST_USER=cj_migration_test
MIGRATION_TEST_PASSWORD=

# MySQL account host entries to create for MIGRATION_TEST_USER.
# Keep 127.0.0.1 if MIGRATION_TEST_HOST uses TCP. Keep localhost if you also
# run the harness with localhost.
MIGRATION_TEST_USER_HOSTS=localhost,127.0.0.1

# Administrative MySQL connection used only by:
#   composer test:migrations:prepare
#
# If root uses unix_socket authentication, set MIGRATION_TEST_ADMIN_SOCKET to
# your MySQL socket path, leave MIGRATION_TEST_ADMIN_PASSWORD empty, and run:
#   sudo php scripts/setup-migration-test-database.php
MIGRATION_TEST_ADMIN_HOST=127.0.0.1
MIGRATION_TEST_ADMIN_PORT=3306
MIGRATION_TEST_ADMIN_SOCKET=
MIGRATION_TEST_ADMIN_USER=root
MIGRATION_TEST_ADMIN_PASSWORD=

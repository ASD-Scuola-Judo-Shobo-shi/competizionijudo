#!/usr/bin/env sh
set -eu

export COMPOSER_CACHE_DIR="${COMPOSER_CACHE_DIR:-$(pwd)/.cache/composer}"

echo "pre-commit: validating Composer metadata"
composer metadata

staged_php_files=$(
  git diff --cached --name-only --diff-filter=ACMR |
    grep -E '^(config|public|routes|src|tests|views)/.*\.php$' || true
)

if [ -z "$staged_php_files" ]; then
  exit 0
fi

echo "pre-commit: checking staged PHP syntax"
printf '%s\n' "$staged_php_files" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    php -l "$file" >/dev/null
  fi
done

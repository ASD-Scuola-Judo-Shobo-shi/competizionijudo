APP_NAME="Competizioni Judo"
APP_ENV=production
APP_DEBUG=false
APP_LOCALE=it
APP_URL=
APP_TEST_RESET_LINKS=false
EVENTS_UPCOMING_LIMIT=12

DB_HOST=127.0.0.1
DB_NAME=
DB_USER=
DB_PASS=

ADMIN_USER=
ADMIN_PASS_HASH=

# Required for GDPR compliance: these values are displayed in the privacy
# notice and make the controller, lawful bases, processors, transfers, and
# retention periods explicit for the actual deployment. Do not deploy with
# placeholders; obtain the legal-basis wording from the data controller.
PRIVACY_CONTROLLER_NAME=
PRIVACY_CONTROLLER_ADDRESS=
PRIVACY_CONTACT_EMAIL=
# Optional when no data protection officer has been appointed.
PRIVACY_DPO_EMAIL=
# Include the applicable GDPR provisions; for athlete/minor data confirm any
# Article 9 condition and the club/guardian authority with the controller.
PRIVACY_ACCOUNT_LEGAL_BASIS=
PRIVACY_ATHLETE_LEGAL_BASIS=
PRIVACY_HOSTING_PROVIDER=
PRIVACY_HOSTING_LOCATION=
PRIVACY_DATA_TRANSFER_DETAILS=
# Optional comma-separated list of other processors or recipients.
PRIVACY_ADDITIONAL_PROCESSORS=
PRIVACY_LOG_RETENTION_DAYS=
PRIVACY_BACKUP_RETENTION_DAYS=

# The migration smoke harness reads these from the process environment, not
# from the deployed application configuration.
# MIGRATION_TEST_DATABASE_PREFIX=competizionijudo_test_local
# MIGRATION_TEST_HOST=127.0.0.1
# MIGRATION_TEST_PORT=3306
# MIGRATION_TEST_USER=root
# MIGRATION_TEST_PASSWORD=
